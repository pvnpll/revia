# PostgreSQL — for Supabase use session pooler from Dashboard → Connect → ORM
# Example: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/revia?schema=public"

# Supabase Auth (optional — without these, the app uses the mock user below)
# Run `npm run supabase:connect` after setting SUPABASE_ACCESS_TOKEN + SUPABASE_PROJECT_REF
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_PROJECT_REF=""

# Local dev fallback when Supabase is not configured
MOCK_USER_ID="00000000-0000-0000-0000-000000000001"
MOCK_USER_EMAIL="demo@decklearning.app"
