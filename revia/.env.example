# PostgreSQL — Supabase pooler (see docs/DEPLOY-VERCEL.md)
# Local dev: session pooler port 5432 for both
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"

# Supabase Auth (optional — without these, the app uses the mock user below)
# Run `npm run supabase:connect` after setting SUPABASE_ACCESS_TOKEN + SUPABASE_PROJECT_REF
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_PROJECT_REF=""

# Local dev fallback when Supabase is not configured
MOCK_USER_ID="00000000-0000-0000-0000-000000000001"
MOCK_USER_EMAIL="demo@decklearning.app"
